---
---
<section class="pt-32 pb-16">
  <div class="max-w-6xl mx-auto px-6 w-full grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

    <!-- Identity -->
    <div>
      <div class="flex items-center gap-5 mb-7">
        <img
          src="/avatar.jpeg"
          alt="Álvaro Alonso González"
          width="72"
          height="72"
          class="w-[72px] h-[72px] rounded-full object-cover object-top border-2 border-amber-500/40 ring-4 ring-amber-500/10"
        />
        <p class="font-mono text-amber-500 text-sm tracking-wider">$ whoami</p>
      </div>

      <h1 class="text-6xl lg:text-7xl font-bold tracking-tight leading-[0.95] mb-6">
        Álvaro<br />
        <span class="text-slate-500">Alonso</span>
      </h1>

      <p class="text-xl text-amber-500 font-semibold mb-5">
        DevOps & Cloud Engineer
      </p>

      <p class="text-slate-400 text-base lg:text-lg leading-relaxed max-w-md mb-10">
        I build infrastructure that scales — Kubernetes clusters, Terraform modules,
        and CI/CD pipelines that let teams ship without friction.
      </p>

      <div class="flex flex-wrap gap-3 mb-12">
        <a
          href="#projects"
          class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-6 py-2.5 rounded text-sm transition-colors"
        >
          View my work
        </a>
        <a
          href="#experience"
          class="text-slate-300 hover:text-white border border-slate-700 hover:border-slate-500 font-medium px-6 py-2.5 rounded text-sm transition-all"
        >
          Experience
        </a>
      </div>

      <div class="flex items-center gap-5 text-slate-500">
        <a href="mailto:alvaroalonsogonzalez96@gmail.com" class="hover:text-amber-500 transition-colors" title="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/alvaro-alonso-gonzalez" target="_blank" rel="noopener" class="hover:text-amber-500 transition-colors" title="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://github.com/cokee96" target="_blank" rel="noopener" class="hover:text-amber-500 transition-colors" title="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
      </div>
    </div>

    <!-- Terminal -->
    <div class="hidden md:block">
      <div class="rounded-xl border border-slate-800 overflow-hidden shadow-2xl shadow-black/60 bg-slate-900">
        <div class="flex items-center gap-1.5 px-4 py-3 bg-slate-800/60 border-b border-slate-700/50">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 font-mono text-xs text-slate-500 flex-1 text-center">alvaro@portfolio: ~</span>
        </div>
        <div class="p-6 font-mono text-sm min-h-72 text-slate-300 leading-6">
          <div>
            <span class="text-emerald-400">alvaro@portfolio</span><span class="text-slate-600">:</span><span class="text-blue-400">~</span><span class="text-slate-400">$ </span><span id="typed-cmd"></span>
          </div>
          <div id="term-content" class="hidden mt-2"></div>
          <div id="cursor-line" class="mt-1 hidden">
            <span class="text-emerald-400">alvaro@portfolio</span><span class="text-slate-600">:</span><span class="text-blue-400">~</span><span class="text-slate-400">$ </span><span class="inline-block w-[9px] h-[15px] bg-amber-500 align-middle" style="animation: blink 1s step-end infinite;"></span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  (async () => {
    const typedCmd = document.getElementById('typed-cmd') as HTMLElement;
    const termContent = document.getElementById('term-content') as HTMLElement;
    const cursorLine = document.getElementById('cursor-line') as HTMLElement;

    if (!typedCmd || !termContent || !cursorLine) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

    async function type(el: HTMLElement, text: string, delay = 75): Promise<void> {
      for (const ch of text) {
        el.textContent += ch;
        await sleep(delay + Math.random() * 25);
      }
    }

    const lines = [
      '<span class="text-slate-600">---</span>',
      '<span class="text-blue-400">name</span><span class="text-slate-500">:</span> <span class="text-amber-300">"Álvaro Alonso González"</span>',
      '<span class="text-blue-400">role</span><span class="text-slate-500">:</span> <span class="text-amber-300">"DevOps & Cloud Engineer"</span>',
      '<span class="text-blue-400">company</span><span class="text-slate-500">:</span> <span class="text-amber-300">"INNOCV [Alkemy]"</span>',
      '<span class="text-blue-400">location</span><span class="text-slate-500">:</span> <span class="text-amber-300">"Madrid, Spain"</span>',
      '<span class="text-blue-400">stack</span><span class="text-slate-500">:</span>',
      '  <span class="text-slate-500">-</span> <span class="text-emerald-400">Azure & Azure DevOps</span>',
      '  <span class="text-slate-500">-</span> <span class="text-emerald-400">Kubernetes + Terraform</span>',
      '  <span class="text-slate-500">-</span> <span class="text-emerald-400">CI/CD Pipelines</span>',
      '  <span class="text-slate-500">-</span> <span class="text-emerald-400">Docker + Helm</span>',
      '<span class="text-blue-400">degree</span><span class="text-slate-500">:</span> <span class="text-amber-300">"MSc Telecom Eng, UPM"</span>',
      '<span class="text-blue-400">status</span><span class="text-slate-500">:</span> <span class="text-emerald-400">building</span>',
    ];

    await sleep(800);
    await type(typedCmd, 'cat profile.yaml');
    await sleep(350);
    termContent.innerHTML = lines.map(l => `<div>${l}</div>`).join('');
    termContent.classList.remove('hidden');
    await sleep(200);
    cursorLine.classList.remove('hidden');
  })();
</script>
