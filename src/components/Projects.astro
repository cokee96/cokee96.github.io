---
const projects = [
  {
    name: 'FocusFarm',
    tagline: 'Android productivity game',
    description:
      'A gamified focus timer where staying off your phone grows your farm. Built with React Native and Expo — fully offline, no backend required.',
    tags: ['React Native', 'Expo', 'TypeScript', 'Zustand', 'Android'],
    badge: 'Android',
    badgeClass: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
    github: 'https://github.com/cokee96/focusfarm',
  },
  {
    name: 'bot-recetas',
    tagline: 'Telegram shopping list + AI recipes',
    description:
      'A Telegram bot that manages your shopping list and suggests recipes powered by DeepSeek AI. Includes a companion web interface for tracking ingredients.',
    tags: ['n8n', 'Telegram Bot API', 'DeepSeek AI', 'JavaScript'],
    badge: 'Telegram Bot',
    badgeClass: 'text-blue-400 bg-blue-500/10 border-blue-500/20',
    github: 'https://github.com/cokee96/bot-recetas',
  },
];
---

<section id="projects" class="py-14 border-t border-slate-900 scroll-mt-16">
  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-10">
      <p class="font-mono text-amber-500 text-xs tracking-widest uppercase mb-3">Side projects</p>
      <h2 class="text-4xl font-bold tracking-tight">Projects</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map(project => (
        <article class="bg-slate-900/50 border border-slate-800 hover:border-slate-700 rounded-xl p-7 flex flex-col gap-5 transition-all hover:bg-slate-900/80 group">

          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-xl font-bold text-slate-100 group-hover:text-white transition-colors mb-1">
                {project.name}
              </h3>
              <p class="text-amber-500/80 text-sm font-medium">{project.tagline}</p>
            </div>
            <span class={`shrink-0 font-mono text-xs px-2.5 py-1 rounded-full border ${project.badgeClass}`}>
              {project.badge}
            </span>
          </div>

          <p class="text-slate-400 text-sm leading-relaxed flex-1">{project.description}</p>

          <div class="flex flex-wrap gap-2">
            {project.tags.map(tag => (
              <span class="font-mono text-xs px-2.5 py-1 bg-[#0a0f1e] border border-slate-800 text-slate-500 rounded">
                {tag}
              </span>
            ))}
          </div>

          <div class="pt-1 border-t border-slate-800">
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-amber-500 transition-colors font-medium"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              View on GitHub
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
