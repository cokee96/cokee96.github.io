---
const groups = [
  { label: 'Cloud', skills: ['Azure'] },
  { label: 'IaC', skills: ['Terraform', 'Ansible', 'AWX'] },
  { label: 'CI/CD', skills: ['Azure DevOps', 'Jenkins', 'GitHub Actions'] },
  { label: 'Containers & Orchestration', skills: ['Kubernetes', 'Docker', 'Helm', 'Argo Workflows'] },
  { label: 'Scripting', skills: ['Python', 'Bash / Shell'] },
  { label: 'Data', skills: ['Apache NiFi'] },
  { label: 'Tools', skills: ['Linux', 'Git', 'Rundeck'] },
];
---

<section id="skills" class="py-14 border-t border-slate-900 scroll-mt-16">
  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-10">
      <p class="font-mono text-amber-500 text-xs tracking-widest uppercase mb-3">Tech stack</p>
      <h2 class="text-4xl font-bold tracking-tight">Skills</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-10">
      {groups.map(({ label, skills }) => (
        <div>
          <p class="font-mono text-xs text-amber-500/60 uppercase tracking-widest mb-4">{label}</p>
          <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
              <span class="text-sm px-3 py-1.5 bg-slate-900 border border-slate-800 hover:border-slate-600 text-slate-300 rounded-lg transition-colors cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
